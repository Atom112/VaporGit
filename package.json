{
  "name": "vaporgit",
  "version": "1.2.5",
  "description": "A lightweight cross-platform GUI Git desktop client built with Tauri + SolidJS.",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--no-deprecation vite",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation vite",
    "check": "tsc --noEmit",
    "check:rust": "cd src-tauri && cargo check",
    "lint": "oxlint src",
    "lint:rust": "cd src-tauri && cargo clippy -- -D warnings",
    "test": "vitest run",
    "test:rust": "cd src-tauri && cargo test",
    "precommit": "npm run check && npm run lint && npm run test && cd src-tauri && cargo check",
    "build": "cross-env NODE_OPTIONS=--no-deprecation vite build",
    "serve": "vite preview",
    "tauri": "tauri",
    "version": "node scripts/bump-version.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@solidjs/router": "^0.16.1",
    "@tanstack/solid-virtual": "^3.13.28",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "solid-js": "^1.9.3",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/user-event": "^14.6.1",
    "cross-env": "^10.1.0",
    "lefthook": "^2.1.9",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.0",
    "terser": "^5.48.0",
    "typescript": "~5.6.2",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  }
}
